# SAM Contract Agent — environment variables
# Copy this file to .env and fill in your credentials.
# The agent runs in demo mode if any key is left blank.

# SAM.gov public API key
# Get it at: https://sam.gov/profile/details (free, requires account)
SAM_API_KEY=

# Cloudflare Browser Rendering
# Account ID: Cloudflare dashboard → right sidebar
# API Token:  Cloudflare → API Tokens → create with "Browser Rendering: Edit" permission
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Anthropic API key
# Get it at: https://console.anthropic.com
ANTHROPIC_API_KEY=